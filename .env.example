# ============================================================================
#  GRC Academy — frontend environment.  Copy to `.env` and fill in.
#  Everything here is PUBLIC (shipped to the browser). Never put secrets here.
#  The app runs with none of these set — auth, data and payments simply
#  stay disabled so you can preview the UI on local/demo state.
# ============================================================================

# --- Clerk (auth + email OTP) --- https://dashboard.clerk.com
# Enable "Email verification code" in Clerk → this is your OTP login.
# Also create a JWT template named "supabase" (see src/lib/supabase.ts).
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase (database, leaderboard, edge functions) --- https://supabase.com
# Settings → API. The anon key is safe to expose (RLS enforces access).
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- Razorpay (public key id only) --- https://dashboard.razorpay.com
# The Key SECRET is NOT here — set it as an edge-function secret instead:
#   supabase secrets set RAZORPAY_KEY_ID=... RAZORPAY_KEY_SECRET=...
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
